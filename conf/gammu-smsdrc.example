# Managed for Quectel EM120R-GL SMS-only gateway.
# Cellular data stays disabled on the PVE host; this VM uses only the AT serial port.
[gammu]
Device = /dev/ttyS0
Connection = at115200
SynchronizeTime = no

[smsd]
Service = files
LogFile = syslog
DebugLevel = 0
PhoneID = quectel-em120r
RunOnReceive = /htdocs/sms/bin/sms-received-hook
InboxPath = /htdocs/sms/spool/inbox/
OutboxPath = /htdocs/sms/spool/outbox/
SentSMSPath = /htdocs/sms/spool/sent/
ErrorSMSPath = /htdocs/sms/spool/error/
InboxFormat = detail
OutboxFormat = detail
TransmitFormat = auto
