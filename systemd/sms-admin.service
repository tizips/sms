# /etc/systemd/system/sms-admin.service
[Unit]
Description=SMS Admin Web Console
After=network-online.target gammu-smsd.service
Wants=network-online.target
[Service]
Type=simple
Environment=SMS_BASE=/htdocs/sms
Environment=LANG=C.UTF-8
Environment=LC_ALL=C.UTF-8
ExecStart=/usr/bin/python3 /htdocs/sms/admin/sms_admin.py
Restart=on-failure
RestartSec=5
WorkingDirectory=/htdocs/sms
[Install]
WantedBy=multi-user.target
