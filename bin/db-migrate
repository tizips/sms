#!/usr/bin/env python3
import os
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
MIGRATIONS = ROOT / "migrations"


def load_psycopg2():
    try:
        import psycopg2
    except ImportError as exc:
        raise SystemExit("python3-psycopg2 is required on this host") from exc
    return psycopg2


def database_url() -> str:
    url = os.environ.get("SMS_DATABASE_URL") or os.environ.get("DATABASE_URL")
    if not url:
        raise SystemExit("set SMS_DATABASE_URL or DATABASE_URL")
    return url


def ensure_migration_table(conn) -> None:
    with conn.cursor() as cur:
        cur.execute(
            """
            CREATE TABLE IF NOT EXISTS schema_migrations (
              version TEXT PRIMARY KEY,
              applied_at TIMESTAMPTZ NOT NULL DEFAULT now()
            )
            """
        )


def applied_versions(conn) -> set[str]:
    with conn.cursor() as cur:
        cur.execute("SELECT version FROM schema_migrations")
        return {row[0] for row in cur.fetchall()}


def apply_migration(conn, path: Path) -> None:
    sql = path.read_text(encoding="utf-8")
    with conn.cursor() as cur:
        cur.execute(sql)
        cur.execute("INSERT INTO schema_migrations (version) VALUES (%s)", (path.name,))


def main() -> int:
    psycopg2 = load_psycopg2()
    conn = psycopg2.connect(database_url())
    try:
        conn.autocommit = False
        ensure_migration_table(conn)
        done = applied_versions(conn)
        for path in sorted(MIGRATIONS.glob("*.sql")):
            if path.name in done:
                print(f"skip {path.name}")
                continue
            print(f"apply {path.name}")
            apply_migration(conn, path)
            conn.commit()
        print("migrations complete")
    finally:
        conn.close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
